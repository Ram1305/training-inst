# Copy to .env and adjust as needed

# API URL - full base URL including /api (e.g. https://localhost:7419/api)
# When using Aspire AppHost, this is auto-injected
VITE_API_URL=https://localhost:7419/api

# Legacy: base URL without /api (used as fallback if VITE_API_URL not set)
VITE_API_BASE_URL=https://localhost:7419

# Set to 'true' to use HTTP instead of HTTPS (avoids SSL cert issues in dev)
# Use with: dotnet run --launch-profile http (API runs on http://localhost:5576)
VITE_USE_HTTP=false

# Optional GA4 ID. Ignored if src/config/analytics.config.ts GTAG_MEASUREMENT_ID is set.
# Otherwise if unset here, the app loads the id from GET {VITE_API_URL}/PublicEnrollment/gtag-config.
VITE_GTAG_ID=
