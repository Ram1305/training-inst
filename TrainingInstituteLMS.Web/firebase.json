{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "@(robots.txt|sitemap.xml)",
        "destination": "/$1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
